# Environment
.env
.env.*
!.env.example
.envrc

# Common secrets and certs
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ecdsa
id_ed25519

# Terraform
deploy/terraform/.terraform/
deploy/terraform/.terraform.lock.hcl
deploy/terraform/terraform.tfstate
deploy/terraform/terraform.tfstate.backup
deploy/terraform/terraform.tfvars
deploy/terraform/*.tfvars
!deploy/terraform/*.tfvars.example

# Ansible
deploy/ansible/inventory.ini
!deploy/ansible/inventory.ini.example
deploy/ansible/*.retry

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
yarn.lock

# Build outputs
dist/
build/
*.js.map

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Backups
backups/
*.tar.gz
*.sql
!**/migrations/*.sql

# Logs
*.log
logs/

# Python
__pycache__/
*.pyc
*.pyo
.venv/

# Temporary files
tmp/
temp/
.cache/

# Archive node_modules and dist (don't track bulk in archive)
archive/**/node_modules/
archive/**/dist/
archive/**/.env

# Kanban runtime data (created at runtime, not committed)
kanban/web-ui/node_modules/
kanban/web-ui/dist/
kanban/node_modules/
kanban/dist/

# Research clones with embedded secrets/git repos
docs/research/pi-mono/

# Memory (lives in external repo, never in app repo)
memory/
