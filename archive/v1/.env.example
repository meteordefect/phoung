# Phoung v2 — Environment Configuration
# Copy to .env and fill in your values:  cp .env.example .env

# --- LLM API Keys (at least one required) ---

# Kimi For Coding (pi-mono provider: kimi-coding)
KIMI_API_KEY=

# ZAI / GLM (pi-mono provider: zai)
ZAI_API_KEY=

# Anthropic (pi-mono provider: anthropic)
ANTHROPIC_API_KEY=

# Default model for Phoung chat (pi-mono provider/model format, empty = auto-select)
DEFAULT_MODEL=

# --- GitHub ---

GITHUB_TOKEN=

# --- Sub-agent Configuration ---

# Model used by spawned coding sub-agents
SUBAGENT_MODEL=zai/glm-4
SUBAGENT_IMAGE=phoung/subagent:latest
SUBAGENT_MEMORY_LIMIT=2g
SUBAGENT_CPUS=2
MAX_CONCURRENT_SUBAGENTS=3

# Container runtime: runsc (gVisor, recommended) or runc (default Docker)
SUBAGENT_RUNTIME=runsc

# --- Paths (defaults work for Docker, override for local dev) ---

REPOS_DIR=/app/repos
WORKSPACES_DIR=/tmp/clawdeploy-workspaces
MEMORY_DIR=/app/memory

# --- API ---

API_HOST=0.0.0.0
API_PORT=8000
